TOKEN=your_discord_bot_token
GUILD_ID=your_server_id
ADMIN_USER_IDS=your_discord_user_id

# Storage: json (local) | sqlite (production / Render)
STORAGE=sqlite
DATABASE_PATH=./data/bot.db

XP_COOLDOWN_MINUTES=5
DAILY_XP_CAP=50
DATA_DIR=./data
LOG_LEVEL=info
SCHEDULER_INTERVAL_MS=3600000
XP_LOG_MAX_ENTRIES=2000

# @bot qua OpenRouter AI — phân loại chào / trả lời / Bot chịu
# https://openrouter.ai/docs/quickstart
# MENTION_AI=true
# OPENROUTER_API_KEY=sk-or-...
# MENTION_AI_MODEL=openai/gpt-4o-mini
# MENTION_MAX_INPUT=300
# MENTION_AI_COOLDOWN_MS=10000
# OPENROUTER_APP_NAME=feedback-bot

# Chống gian lận (mặc định nếu không set)
# XP_COOLDOWN_MINUTES=5
# THREAD_COOLDOWN_MINUTES=3
# DAILY_XP_CAP=50
# VELOCITY_XP_PER_HOUR=35
# FINGERPRINT_MEMORY=50
# FINGERPRINT_RETENTION_DAYS=90
# SIMILAR_TEXT_MEMORY=30
# GLOBAL_IMAGE_DEDUP=true
# GLOBAL_TEXT_DEDUP=true
# GLOBAL_CROSS_SIMILARITY=true
# NEW_ACCOUNT_AGE_DAYS=7
# NEW_ACCOUNT_DAILY_CAP=20
# NEW_ACCOUNT_VELOCITY_CAP=20
# ALT_STRIKE_LIMIT=3
# ALT_STRIKE_BLOCK_HOURS=24

# --- Render (dashboard.render.com → Environment, không commit .env) ---
# Loại service: Background Worker + Docker (render.yaml)
# TOKEN, GUILD_ID, ADMIN_USER_IDS, OPENROUTER_API_KEY → sync: false (nhập tay lúc deploy)
# STORAGE=sqlite
# DATA_DIR=/app/data
# DATABASE_PATH=/app/data/bot.db
#
# Disk (bắt buộc — Starter plan trở lên, không thì mất XP khi redeploy):
#   render.yaml đã cấu hình disk mountPath: /app/data
#
# Deploy:
#   1. Push repo lên GitHub (private OK)
#   2. Render → New → Blueprint → chọn repo → Apply
#   3. Nhập secret env khi được hỏi
#   4. Logs: Service → Logs — thấy "Storage ready", bot online
#
# Chỉ 1 instance (worker không scale ngang). Tắt npm start local khi chạy Render.
# Migrate data: npm run migrate:sqlite → upload bot.db vào disk (Render Shell hoặc redeploy với file trong image — khuyên dùng disk trống lần đầu).
